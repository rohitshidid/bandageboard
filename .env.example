# Postgres connection string (Vercel Postgres / Neon / local).
# Local example: postgres://postgres:postgres@localhost:5432/bandageboard
DATABASE_URL=

# PCC mock API base URL.
PCC_BASE_URL=https://hackathon.prod.pulsefoundry.ai

# Optional shared secret to protect POST/GET /api/sync. Leave blank to disable.
SYNC_SECRET=

# Person 2 — LLM extraction for Envive narratives (runs on de-identified text only).
ANTHROPIC_API_KEY=
# Optional: override the extraction model (default claude-opus-4-8).
EXTRACT_MODEL=
# Set to "true" to route hard narratives through the LLM in /api/eligibility.
# Default off keeps the per-request path deterministic, fast, and free.
EXTRACT_USE_LLM=
